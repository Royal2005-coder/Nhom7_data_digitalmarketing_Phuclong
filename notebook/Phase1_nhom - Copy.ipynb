   "source": [
    "# ========== 5.3.1 - Làm sạch cơ bản và chuẩn hóa Teencode ==========\n",
    "import re\n",
    "import pandas as pd\n",
    "\n",
    "# Từ điển Teencode mở rộng\n",
    "TEENCODE_DICT = {\n",
    "    'ko': 'không', 'k': 'không', 'khg': 'không', 'kh': 'không', 'k0': 'không', 'hông': 'không', 'hổng': 'không',\n",
    "    'dc': 'được', 'đc': 'được', 'dược': 'được', 'duoc': 'được',\n",
    "    'gđ': 'gia đình', 'gd': 'gia đình', 'dth': 'dễ thương', 'dthw': 'dễ thương', 'cute': 'dễ thương',\n",
    "    'trc': 'trước', 'truoc': 'trước', 'sau': 'sau', 'chx': 'chưa', 'troll': 'trêu đùa',\n",
    "    'nv': 'nhân viên', 'staff': 'nhân viên', 'ks': 'khách sạn', 'phòng': 'phòng', 'gấp': 'gấp',\n",
    "    'pl': 'phúc long', 'hl': 'highlands', 'coffee': 'cà phê', 'cf': 'cà phê', 'cafe': 'cà phê',\n",
    "    'fb': 'facebook', 'tt': 'tiktok', 'ad': 'admin', 'page': 'trang chủ',\n",
    "    'iu': 'yêu', 'love': 'yêu', 'like': 'thích', 'thik': 'thích', 'thx': 'cảm ơn', 'cảm ơn': 'cảm ơn',\n",
    "    'đt': 'điện thoại', 'dt': 'điện thoại', 'ib': 'nhắn tin', 'inbox': 'nhắn tin', 'cmt': 'bình luận', 'comment': 'bình luận',\n",
    "    'ks': 'khách sạn', 'helo': 'xin chào', 'hello': 'xin chào', 'hi': 'xin chào', 'lmao': 'cười lớn', 'lol': 'cười lớn',\n",
    "    'mn': 'mọi người', 'mng': 'mọi người', 'vs': 'với', 'j': 'gì', 'g': 'gì', 'thui': 'thôi', 'đag': 'đang'\n",
    "}\n",
    "\n",
    "def clean_teencode(text):\n",
    "    if not isinstance(text, str):\n",
    "        return \"\"\n",
    "    # Chuyển về chữ thường và xóa các ký tự đặc biệt cơ bản\n",
    "    text = text.lower().strip()\n",
    "    text = re.sub(r'[\\r\\n]+', ' ', text)\n",
    "    text = re.sub(r'[^a-záàảãạăắằẳẵặâấầẩẫậéèẻẽẹêếềểễệíìỉĩịóòỏõọôốồổỗộơớờởỡợúùủũụưứừửữựýỳỷỹỵđ\\s_]', ' ', text)\n",
    "    \n",
    "    words = text.split()\n",
    "    cleaned_words = [TEENCODE_DICT.get(w, w) for w in words]\n",
    "    return \" \".join(cleaned_words)\n",
    "\n",
    "print(\"Bản đồ chuẩn hóa Teencode đã được định nghĩa thành công.\")"
   ]
