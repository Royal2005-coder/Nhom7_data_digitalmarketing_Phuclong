   "source": [
    "# ========== 5.4.5 - Chạy Batch Inference trên tập dữ liệu còn lại ==========\n",
    "import torch\n",
    "import numpy as np\n",
    "from torch.utils.data import DataLoader, SequentialSampler, TensorDataset\n",
    "from tqdm import tqdm\n",
    "\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "\n",
    "# Nạp clean comments và loại trừ tập Train và Test để chống data leakage\n",
    "df_clean = pd.read_csv(os.path.join(data_dir, \"clean_comments.csv\"))\n",
    "df_clean[\"norm_text\"] = df_clean[\"comment_text\"].astype(str).str.strip().str.lower()\n",
    "\n",
    "df_train_raw = pd.read_csv(os.path.join(data_dir, \"stratified_sample_2000.csv\"))\n",
    "df_test_raw  = pd.read_csv(os.path.join(data_dir, \"test_500_comments.csv\"))\n",
    "df_train_raw[\"norm_text\"] = df_train_raw[\"comment_text\"].astype(str).str.strip().str.lower()\n",
    "df_test_raw[\"norm_text\"]  = df_test_raw[\"comment_text\"].astype(str).str.strip().str.lower()\n",
    "\n",
    "train_norms = set(df_train_raw[\"norm_text\"])\n",
    "test_norms  = set(df_test_raw[\"norm_text\"])\n",
    "excluded_norms = train_norms.union(test_norms)\n",
    "\n",
    "df_inference = df_clean[~df_clean[\"norm_text\"].isin(excluded_norms)].copy()\n",
    "df_inference = df_inference[df_inference['clean_text'].fillna('').str.strip() != ''].copy()\n",
    "\n",
    "texts = df_inference['clean_text'].astype(str).tolist()\n",
    "\n",
    "print(\"Bắt đầu tokenize văn bản tập inference...\")\n",
    "encodings = tokenizer(\n",
    "    texts,\n",
    "    truncation=True,\n",
    "    padding='max_length',\n",
    "    max_length=64,\n",
    "    return_tensors='pt'\n",
    ")\n",
    "\n",
    "dataset = TensorDataset(encodings['input_ids'], encodings['attention_mask'])\n",
    "sampler = SequentialSampler(dataset)\n",
    "dataloader = DataLoader(dataset, sampler=sampler, batch_size=32)\n",
    "\n",
    "preds = []\n",
    "scores = []\n",
    "id2label = {0: \"Negative\", 1: \"Positive\", 2: \"Neutral\"}\n",
    "\n",
    "print(\"Bắt đầu chạy batch inference sử dụng Model A...\")\n",
    "model_a.to(device)\n",
    "model_a.eval()\n",
    "with torch.no_grad():\n",
    "    for batch in tqdm(dataloader):\n",
    "        input_ids, attention_mask = [t.to(device) for t in batch]\n",
    "        outputs = model_a(input_ids=input_ids, attention_mask=attention_mask)\n",
    "        logits = outputs.logits\n",
    "        probs = torch.softmax(logits, dim=-1)\n",
    "        batch_scores, batch_preds = torch.max(probs, dim=-1)\n",
    "        preds.extend(batch_preds.cpu().numpy())\n",
    "        scores.extend(batch_scores.cpu().numpy())\n",
    "\n",
    "df_inference['sentiment_label'] = [id2label[p] for p in preds]\n",
    "df_inference['sentiment_score'] = scores\n",
    "df_inference['source'] = 'predicted'\n",
    "\n",
    "print(\"\\nHoàn thành gán nhãn cho tập inference!\")\n",
    "print(df_inference['sentiment_label'].value_counts())"
   ]
  },
  {
   "cell_type": "markdown",
