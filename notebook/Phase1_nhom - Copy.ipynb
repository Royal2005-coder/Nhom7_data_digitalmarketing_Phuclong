   "source": [
    "### 5.4.3 - Huấn luyện LoRA với hai kịch bản \n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 79,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Đang khởi tạo hoặc tải Model A (Baseline)...\n",
      "[INFO] Phát hiện mô hình Model_A_Baseline đã được huấn luyện sẵn. Đang tải adapter...\n",
      "Đang khởi tạo hoặc tải Model B (Proposed)...\n",
      "[INFO] Phát hiện mô hình Model_B_Proposed đã được huấn luyện sẵn. Đang tải adapter...\n"
     ]
    }
   ],
   "source": [
    "# ========== 5.4.3 - Huấn luyện LoRA với hai kịch bản ==========\n",
    "from transformers import AutoModelForSequenceClassification, Trainer, TrainingArguments\n",
    "from peft import LoraConfig, get_peft_model, TaskType, PeftModel\n",
    "from sklearn.metrics import accuracy_score, f1_score\n",
    "import os\n",
    "os.environ[\"WANDB_DISABLED\"] = \"true\"\n",
    "import numpy as np\n",
    "\n",
    "force_retrain = False\n",
    "\n",
    "lora_config = LoraConfig(\n",
    "    task_type=TaskType.SEQ_CLS,\n",
    "    r=8,\n",
    "    lora_alpha=32,\n",
    "    lora_dropout=0.1,\n",
    "    target_modules=[\"query\", \"value\"]\n",
    ")\n",
    "\n",
    "def compute_metrics(eval_pred):\n",
    "    logits, labels = eval_pred\n",
    "    preds = np.argmax(logits, axis=-1)\n",
    "    acc = accuracy_score(labels, preds)\n",
    "    macro_f1 = f1_score(labels, preds, average='macro')\n",
    "    weighted_f1 = f1_score(labels, preds, average='weighted')\n",
    "    return {'accuracy': acc, 'macro_f1': macro_f1, 'weighted_f1': weighted_f1}\n",
    "\n",
    "model_save_dir_a = os.path.join(data_dir, \"visobert_fb_model_baseline\")\n",
    "model_save_dir_b = os.path.join(data_dir, \"visobert_fb_model\")\n",
    "\n",
    "# 1. Model A Baseline\n",
    "print(\"Đang khởi tạo hoặc tải Model A (Baseline)...\")\n",
    "if not force_retrain and os.path.exists(model_save_dir_a):\n",
    "    print(\"[INFO] Phát hiện mô hình Model_A_Baseline đã được huấn luyện sẵn. Đang tải adapter...\")\n",
    "    base_model_a = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=3)\n",
    "    model_a = PeftModel.from_pretrained(base_model_a, model_save_dir_a)\n",
    "    trainer_a = Trainer(model=model_a, compute_metrics=compute_metrics)\n",
    "else:\n",
    "    base_model_a = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=3)\n",
    "    model_a = get_peft_model(base_model_a, lora_config)\n",
    "    training_args_a = TrainingArguments(\n",
    "        output_dir='./pre_audit_Model_A_Baseline_PreAudit',\n",
    "        num_train_epochs=1,\n",
    "        per_device_train_batch_size=16,\n",
    "        learning_rate=2e-5,\n",
    "        use_cpu=True,\n",
    "        report_to='none'\n",
    "    )\n",
    "    trainer_a = Trainer(\n",
    "        model=model_a,\n",
    "        args=training_args_a,\n",
    "        train_dataset=train_dataset_a,\n",
    "        compute_metrics=compute_metrics\n",
    "    )\n",
    "    trainer_a.train()\n",
    "\n",
    "# 2. Model B Proposed\n",
    "print(\"Đang khởi tạo hoặc tải Model B (Proposed)...\")\n",
    "if not force_retrain and os.path.exists(model_save_dir_b):\n",
    "    print(\"[INFO] Phát hiện mô hình Model_B_Proposed đã được huấn luyện sẵn. Đang tải adapter...\")\n",
    "    base_model_b = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=3)\n",
    "    model_b = PeftModel.from_pretrained(base_model_b, model_save_dir_b)\n",
    "    trainer_b = Trainer(model=model_b, compute_metrics=compute_metrics)\n",
    "else:\n",
    "    base_model_b = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=3)\n",
    "    model_b = get_peft_model(base_model_b, lora_config)\n",
    "    training_args_b = TrainingArguments(\n",
    "        output_dir='./pre_audit_Model_B_Proposed_PreAudit',\n",
    "        num_train_epochs=1,\n",
    "        per_device_train_batch_size=16,\n",
    "        learning_rate=2e-5,\n",
    "        use_cpu=True,\n",
    "        report_to='none'\n",
    "    )\n",
    "    trainer_b = Trainer(\n",
    "        model=model_b,\n",
    "        args=training_args_b,\n",
    "        train_dataset=train_dataset_b,\n",
    "        compute_metrics=compute_metrics\n",
    "    )\n",
    "    trainer_b.train()"
   ]
