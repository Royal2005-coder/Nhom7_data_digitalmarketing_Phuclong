   "source": [
    "# ========== 5.6.1 - Trích xuất chủ đề bằng NMF ==========\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.decomposition import NMF\n",
    "\n",
    "print(\"Bắt đầu trích xuất các chủ đề bằng NMF...\")\n",
    "tfidf_vectorizer = TfidfVectorizer(max_df=0.9, min_df=2, max_features=1000)\n",
    "tfidf_matrix = tfidf_vectorizer.fit_transform(df_all_11k['clean_text'].astype(str))\n",
    "\n",
    "nmf = NMF(n_components=4, random_state=42, init='nndsvd')\n",
    "nmf.fit(tfidf_matrix)\n",
    "\n",
    "topic_values = nmf.transform(tfidf_matrix)\n",
    "df_all_11k['topic_id'] = np.argmax(topic_values, axis=1)\n",
    "\n",
    "topic_name_map = {\n",
    "    0: \"Thảo luận hành vi chung & Tương tác sản phẩm\",\n",
    "    1: \"Trải nghiệm cảm quan & Đánh giá chất lượng vị\",\n",
    "    2: \"Vận hành thương mại (Mua bán/Vé/App/Tình trạng hàng)\",\n",
    "    3: \"Biểu cảm thẩm mỹ & Sắc thái thiện cảm cao\"\n",
    "}\n",
    "df_all_11k['topic_name'] = df_all_11k['topic_id'].map(topic_name_map)\n",
    "df_final['topic_id'] = df_all_11k['topic_id']\n",
    "df_final['topic_name'] = df_all_11k['topic_name']\n",
    "\n",
    "feature_names = tfidf_vectorizer.get_feature_names_out()\n",
    "for topic_idx, topic in enumerate(nmf.components_):\n",
    "    top_features_ind = topic.argsort()[:-11:-1]\n",
    "    top_features = [feature_names[i] for i in top_features_ind]\n",
    "    print(f\"Chủ đề {topic_idx} ({topic_name_map[topic_idx]}):\")\n",
    "    print(\" - Từ khóa:\", \", \".join(top_features))\n",
    "\n",
    "print(\"\\nPhân phối chủ đề thành công.\")"
   ]
